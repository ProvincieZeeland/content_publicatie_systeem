{
  "APPLICATIONINSIGHTS_AUTHENTICATION_STRING": "Authorization=AAD",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YourTenantId",
    "ClientId": "YourClientId",
    "ClientCredentials": [
      {
        "SourceType": "KeyVault",
        "KeyVaultUrl": "YourKeyVaultUrl",
        "KeyVaultCertificateName": "YourKeyVaultCertificateName"
      }
    ]
  },
  "ConnectionStrings": {
    "AZURE_SQL_CONNECTIONSTRING": "YourSqlConnectionString"
  },
  "DownstreamApi": {
    "BaseUrl": "https://graph.microsoft.com/v1.0",
    "RequestAppToken": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Warning",
        "Microsoft.Identity": "Error"
      }
    }
  },
  "AllowedHosts": "*",
  "RedirectUri": "YourRedirectUri",
  "GlobalSettings": {
    "FileStorageConnectionstring": "YourFileStorageConnectionstring",

    "ContentContainerName": "YourContentContainerName",
    "MetadataContainerName": "YourMetadataContainerName",

    "CallbackUrl": "YourCallbackUrl",
    "CallbackAccessToken": "YourCallbackAccessToken",
    "LoggingLevel": "Debug",

    "TenantId": "YourTenantId",
    "ClientId": "YourClientId",
    "KeyVaultName": "YourKeyVaultName",
    "CertificateName": "YourCertificateName",

    "TermStoreName": "YourTermstoreName",
    "AdditionalObjectId": "OptionalExternalID",
    "MetadataMapping": [],
    "ExternalReferencesMapping": [],
    "DropOffMetadataMapping": [],
    "LocationMapping": [],
    "HostName": "YourHostName",

    "WebHookSettings": {
      "EndPoint": "YourWebHookEndPoint",
      "CreateEnabled": "false",
      "ClientState": "YourWebHookClientState"
    }
  }
}